target/
**/*.rs.bk

# Raw fetched data and intermediate build artifacts are regenerable from
# the sha256-pinned upstream snapshot (`de-morph-build all` downloads it).
# Processed outputs (e.g. data/wiktionary/processed/nouns.jsonl) are also
# regenerable from raw/ via the extractors and would bloat the repo if
# committed. The shipped artifact (compiled FST) lives under dist/ with
# its own provenance entry; it is not under data/.
/data/**/raw/
/data/**/build/
/data/**/processed/

# Built lexicon artifacts (FST + side table) and eval diagnostics.
# Regenerable from data/wiktionary/ via the extractor + build-lexicon
# binaries; large binaries that would bloat history, so they live on
# disk untracked.
/data/lexicon/*.fst
/data/lexicon/*.dat
/data/lexicon/*.jsonl

# Packaged CC BY-SA data bundles (`de-morph-build package` output).
# Regenerable from the snapshot; shipped as release assets, not committed.
/dist/

# Exclude claude files
/docs/

# Editor / OS noise
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
