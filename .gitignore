target/
**/*.rs.bk

# Raw fetched data and intermediate build artifacts are regenerable from
# the fetch scripts + sha256-pinned upstream snapshots. Processed outputs
# (e.g. data/wiktionary/processed/nouns.jsonl) are also regenerable from
# raw/ via the extractor binaries and would bloat the repo if committed.
# The eventual shipped artifact (compiled FST) lives elsewhere under its
# own provenance entry; it is not under data/.
/data/**/raw/
/data/**/build/
/data/**/processed/

# Built lexicon artifacts (FST + side table) and eval diagnostics.
# Regenerable from data/wiktionary/ via the extractor + build-lexicon
# binaries; large binaries that would bloat history, so they live on
# disk untracked.
/data/lexicon/*.fst
/data/lexicon/*.dat
/data/lexicon/*.jsonl

# Packaged CC BY-SA data bundles (scripts/build/package-data.sh output).
# Regenerable from the snapshot; shipped as release assets, not committed.
/dist/

# Editor / OS noise
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
